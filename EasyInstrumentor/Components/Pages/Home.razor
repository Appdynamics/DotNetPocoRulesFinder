@page "/"
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Elevation="0" Class="pa-8" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px;">
        <MudGrid>
            <MudItem xs="12" Class="d-flex flex-column align-center justify-center text-center" Style="min-height: 300px;">
                <MudIcon Icon="@Icons.Material.Filled.Analytics" Style="font-size: 80px; color: white; margin-bottom: 24px;" />
                <MudText Typo="Typo.h3" Style="color: white; font-weight: 600; margin-bottom: 16px;">
                    Welcome to
                </MudText>
                <MudText Typo="Typo.h2" Style="color: white; font-weight: 700; margin-bottom: 24px;">
                    Dotnet POCO Detector
                </MudText>
                <MudText Typo="Typo.h6" Style="color: rgba(255,255,255,0.9); max-width: 600px; margin-bottom: 32px;">
                    Advanced ETW tracing tool for analyzing .NET applications and identifying POCO classes with call stack analysis
                </MudText>
                <MudButtonGroup Variant="Variant.Filled" Size="Size.Large" Style="gap: 16px;">
                    <MudButton 
                        Color="Color.Surface"
                        OnClick="@(() => Navigation.NavigateTo("/capture"))"
                        StartIcon="@Icons.Material.Filled.PlayArrow"
                        Style="padding: 12px 32px; border-radius: 8px; text-transform: none; font-size: 1.1rem;">
                        Get Started
                    </MudButton>
                    <MudButton 
                        Color="Color.Surface"
                        Variant="Variant.Outlined"
                        OnClick="@(() => Navigation.NavigateTo("/about"))"
                        StartIcon="@Icons.Material.Filled.Info"
                        Style="padding: 12px 32px; border-radius: 8px; text-transform: none; font-size: 1.1rem; border-color: white; color: white;">
                        About
                    </MudButton>
                </MudButtonGroup>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudGrid Class="mt-8">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-6" Style="border-radius: 12px; height: 100%; cursor: pointer; transition: transform 0.2s;" 
                      @onclick="@(() => Navigation.NavigateTo("/capture"))">
                <MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Primary" Style="font-size: 48px; margin-bottom: 16px;" />
                <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Process Discovery</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Automatically detect and list all running .NET processes for analysis
                </MudText>
                <MudButton 
                    Color="Color.Primary" 
                    Variant="Variant.Text" 
                    EndIcon="@Icons.Material.Filled.ArrowForward"
                    Class="mt-3"
                    Style="text-transform: none;">
                    View Processes
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-6" Style="border-radius: 12px; height: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Primary" Style="font-size: 48px; margin-bottom: 16px;" />
                <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Real-time Tracing</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Capture JIT compilation, thread activity, and method execution in real-time
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-6" Style="border-radius: 12px; height: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.CallToAction" Color="Color.Primary" Style="font-size: 48px; margin-bottom: 16px;" />
                <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Call Stack Analysis</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    View detailed call stacks and execution paths for captured methods
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .mud-paper:hover {
        transform: translateY(-2px);
    }
</style>
