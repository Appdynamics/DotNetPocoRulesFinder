@page "/process-detail/{OldPid:int}"
@using EasyInstrumentor.Models
@using EasyInstrumentor.Services.Capture
@inject ProcessService ProcessService
@inject CaptureService captureService
@inject NavigationManager Navigation
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    
    <MudPaper Elevation="0" Class="mb-4 pa-4" Style="border-radius: 12px; border-left: 4px solid #1976d2;">
        <MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 600;">
            <MudIcon Icon="@Icons.Material.Filled.MonitorHeart" Class="mr-2" />
            Process Monitoring
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Capture class, method, and call stack events during application execution
        </MudText>
    </MudPaper>

    @if (_process == null)
    {
        <MudPaper Elevation="2" Class="pa-8 d-flex flex-column align-center justify-center" Style="border-radius: 12px; min-height: 300px;">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Class="mt-4">Loading process information...</MudText>
        </MudPaper>
    }
    else
    {
        <MudGrid Spacing="3">
            <!-- Original Process Info -->
            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px; height: 100%;">
                    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" Color="Color.Info" />
                        Original Process
                    </MudText>
                    <MudDivider Class="mb-3" />
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Tag">
                            <MudText Typo="Typo.body2">
                                <strong>Process ID:</strong> <MudChip T="string" Size="Size.Small">@_process.ProcessId</MudChip>
                            </MudText>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Label">
                            <MudText Typo="Typo.body2">
                                <strong>Name:</strong> @_process.ProcessName
                            </MudText>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Terminal">
                            <MudText Typo="Typo.body2" Style="word-break: break-all;">
                                <strong>Command Line:</strong><br />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@_process.CommandLine</MudText>
                            </MudText>
                        </MudListItem>
                    </MudList>
                </MudPaper>
            </MudItem>

            <!-- New Process Info / Instructions -->
            <MudItem xs="12" md="6">
                @if (_newProcess != null)
                {
                    <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px; height: 100%; background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);">
                        <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600; color: white;">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" Style="color: white;" />
                            New Process Detected!
                        </MudText>
                        <MudDivider Class="mb-3" Style="background: rgba(255,255,255,0.3);" />
                        <MudList T="string" Dense="true">
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Tag" IconColor="Color.Surface">
                                <MudText Typo="Typo.body2" Style="color: white;">
                                    <strong>Process ID:</strong> <MudChip T="string" Size="Size.Small" Style="background: white; color: #2e7d32;">@_newProcess.ProcessId</MudChip>
                                </MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Label" IconColor="Color.Surface">
                                <MudText Typo="Typo.body2" Style="color: white;">
                                    <strong>Name:</strong> @_newProcess.ProcessName
                                </MudText>
                            </MudListItem>
                        </MudList>
                        
                        <MudDivider Class="my-3" Style="background: rgba(255,255,255,0.3);" />
                        
                        <MudButton 
                            Disabled="@IsSubmitting" 
                            OnClick="NavigateToBtDetails" 
                            Variant="Variant.Filled" 
                            Color="Color.Surface"
                            FullWidth="true"
                            Size="Size.Large"
                            StartIcon="@Icons.Material.Filled.Stop"
                            Style="border-radius: 8px; text-transform: none; font-weight: 600;">
                            @if (IsSubmitting)
                            {
                                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                                <span>Processing trace data...</span>
                            }
                            else
                            {
                                <span>Stop Capture & View Results</span>
                            }
                        </MudButton>
                    </MudPaper>
                }
                else
                {
                    <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px; height: 100%; background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);">
                        <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600; color: white;">
                            <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Class="mr-2" Style="color: white;" />
                            Waiting for Restart
                        </MudText>
                        <MudDivider Class="mb-3" Style="background: rgba(255,255,255,0.3);" />
                        <MudText Typo="Typo.body1" Style="color: white;" Class="mb-3">
                            Trace capture is now active. Please:
                        </MudText>
                        <MudList T="string" Dense="true">
                            <MudListItem T="string" Icon="@Icons.Material.Filled.RestartAlt" IconColor="Color.Surface">
                                <MudText Style="color: white;">Restart the application</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.PlayArrow" IconColor="Color.Surface">
                                <MudText Style="color: white;">Perform your target transactions</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Timer" IconColor="Color.Surface">
                                <MudText Style="color: white;">Wait for the new process to be detected</MudText>
                            </MudListItem>
                        </MudList>
                        <MudAlert Severity="Severity.Info" Class="mt-3" Style="background: rgba(255,255,255,0.2); color: white;">
                            <MudText Typo="Typo.body2" Style="color: white;">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" />
                                Auto-detecting process restart...
                            </MudText>
                        </MudAlert>
                    </MudPaper>
                }
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="2" Class="pa-4 mt-4 d-flex justify-space-between align-center" Style="border-radius: 12px;">
            <MudButton 
                Color="Color.Secondary" 
                Variant="Variant.Outlined" 
                OnClick="NavigateToHome"
                StartIcon="@Icons.Material.Filled.ArrowBack"
                Style="border-radius: 8px; text-transform: none;">
                Cancel & Go Back
            </MudButton>
            
            @if (_newProcess == null)
            {
                <MudChip T="string" Icon="@Icons.Material.Filled.Visibility" Color="Color.Primary" Size="Size.Medium">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                    Monitoring for restart...
                </MudChip>
            }
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter]
    public int OldPid { get; set; }

    private DotnetProcess? _process;
    private DotnetProcess? _newProcess;
    private Timer? _monitorTimer;
    private bool _processFound = false;
    private bool IsSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await InitializeComponent();
    }

    protected override async Task OnParametersSetAsync()
    {
        // This is called when navigating to the same component with different parameters
        // Reset everything when the PID changes
        await InitializeComponent();
    }

    private async Task InitializeComponent()
    {
        // Clean up existing timer
        _monitorTimer?.Dispose();
        _monitorTimer = null;

        // Reset all state
        _newProcess = null;
        _processFound = false;
        IsSubmitting = false;

        // Load the process info
        _process = await ProcessService.GetProcessByIdAsync(OldPid);
        
        // Only start capture if process was found
        if (_process != null)
        {
            // Start capture without awaiting - it will run in background
            _ = captureService.StartCapture(_process.CommandLine, OldPid);
            
            // Give it a moment to initialize
            await Task.Delay(500);
            
            StartMonitoringForNewProcess();
        }
    }

    private void StartMonitoringForNewProcess()
    {
        _monitorTimer = new Timer(_ => _ = MonitorProcessAsync(), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private async Task MonitorProcessAsync()
    {
        if (_process == null || _processFound) return;

        try
        {
            var match = await captureService.GetNewProcessData();
            if (match != null)
            {
                _newProcess = match;
                _processFound = true;
                _monitorTimer?.Dispose();
                _monitorTimer = null;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error monitoring process: {ex.Message}");
        }
    }

    private async void NavigateToBtDetails()
    {
        if (_newProcess == null) return;

        IsSubmitting = true;
        StateHasChanged();
        
        if (await captureService.StopCapture(false))
        {
            string url = $"/btdetails?ProcessId={_newProcess.ProcessId}";
            CleanupResources();
            Navigation.NavigateTo(url);
        }
        
        IsSubmitting = false;
    }

    private async void NavigateToHome()
    {
        CleanupResources();
        await captureService.StopCapture(true);
        Navigation.NavigateTo($"/capture?fromPage=processdetail");
    }

    private void CleanupResources()
    {
        _processFound = false;
        _newProcess = null;
        _monitorTimer?.Dispose();
        _monitorTimer = null;
    }

    public void Dispose()
    {
        CleanupResources();
    }
}